# ==========================================
# NovelTrans 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# ==========================================

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=novel_translator
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your_jwt_secret_min_32_chars

# Mail (QQ邮箱示例)
MAIL_USERNAME=your_email@qq.com
MAIL_PASSWORD=your_smtp_authorization_code

# Python Translation Service
PYTHON_TRANSLATE_URL=http://localhost:8000/translate

# Internal service-to-service authentication (Java Backend ↔ Python Translation Service)
# Must be a strong random string, shared by both services
TRANSLATE_SERVICE_API_KEY=your_shared_secret_min_32_chars

# MTranServer
MTRAN_HOST=localhost
MTRAN_PORT=8989
# MTranServer internal authentication (shared secret)
MTRAN_API_KEY=your_mtran_secret_min_32_chars

LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Embedding API (RAG)
# 方式一：OpenAI 兼容 API（推荐，支持 DashScope/硅基流动/智谱 等）
EMBEDDING_PROVIDER=openai
EMBEDDING_OPENAI_API_KEY=sk-your_key
EMBEDDING_OPENAI_BASE_URL=https://api.openai.com
EMBEDDING_OPENAI_MODEL=text-embedding-3-small
# DashScope（通义千问）示例：
# EMBEDDING_OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBEDDING_OPENAI_MODEL=text-embedding-v4
# 方式二：Ollama 本地自部署（需 NVIDIA GPU）
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_OLLAMA_BASE_URL=http://localhost:11434
# EMBEDDING_OLLAMA_MODEL=bge-m3

# Translation OpenAI API (可选)
TRANSLATION_OPENAI_API_KEY=

# Stripe 支付（Test 模式）
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret
STRIPE_SUCCESS_URL=http://localhost:7341/subscription/result
STRIPE_CANCEL_URL=http://localhost:7341/subscription/result?canceled=true
STRIPE_PRO_MONTHLY_PRICE_ID=price_pro_monthly
STRIPE_PRO_YEARLY_PRICE_ID=price_pro_yearly
STRIPE_MAX_MONTHLY_PRICE_ID=price_max_monthly
STRIPE_MAX_YEARLY_PRICE_ID=price_max_yearly

# Stripe Account ID 前缀（用于 webhook 压测生成 event ID）
STRIPE_ACCOUNT_PREFIX=YOUR_PREFIX
