# ==========================================
# NovelTrans 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# ==========================================

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=novel_translator
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your_jwt_secret_min_32_chars

# Mail (QQ邮箱示例)
MAIL_USERNAME=your_email@qq.com
MAIL_PASSWORD=your_smtp_authorization_code

# Python Translation Service
PYTHON_TRANSLATE_URL=http://localhost:8000/translate

# MTranServer
MTRAN_HOST=localhost
MTRAN_PORT=8989

LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Embedding API (RAG)
# 方式一：OpenAI API
EMBEDDING_PROVIDER=openai
EMBEDDING_OPENAI_API_KEY=sk-your_openai_key
EMBEDDING_OPENAI_BASE_URL=https://api.openai.com
# 方式二：Ollama 本地自部署（Docker 环境下默认使用 ollama 服务）
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_OLLAMA_BASE_URL=http://localhost:11434
# EMBEDDING_OLLAMA_MODEL=bge-m3

# Translation OpenAI API (可选)
TRANSLATION_OPENAI_API_KEY=

# Stripe 支付（Test 模式）
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret
STRIPE_SUCCESS_URL=http://localhost:5173/subscription/result
STRIPE_CANCEL_URL=http://localhost:5173/subscription/result?canceled=true
STRIPE_PRO_MONTHLY_PRICE_ID=price_pro_monthly
STRIPE_PRO_YEARLY_PRICE_ID=price_pro_yearly
STRIPE_MAX_MONTHLY_PRICE_ID=price_max_monthly
STRIPE_MAX_YEARLY_PRICE_ID=price_max_yearly
