FROM maven:3.9-eclipse-temurin-21 AS builder
WORKDIR /app
COPY pom.xml maven-settings.xml ./
RUN mvn dependency:go-offline -B -s maven-settings.xml
COPY src ./src
RUN mvn package -DskipTests -B -s maven-settings.xml

FROM eclipse-temurin:21-jre-alpine
WORKDIR /app
RUN addgroup -S noveltrans && adduser -S noveltrans -G noveltrans
COPY --from=builder /app/target/novelTranslator-0.0.1-SNAPSHOT.jar app.jar
USER noveltrans
EXPOSE 8080
ENTRYPOINT ["java", "-jar", "app.jar"]
