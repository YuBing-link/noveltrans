# ==========================================
# Load Test 环境变量配置模板
# 复制此文件为 .env（与项目根目录 .env 共用）
# 或直接填写项目根目录的 .env 文件
# ==========================================

# Webhook 压测（webhook_idempotency.py）
WEBHOOK_URL=http://localhost:7341/webhook/stripe
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret
STRIPE_ACCOUNT_PREFIX=TEST_PREFIX

# 测试用 Stripe 对象 ID（由 Stripe 平台创建的真实 ID）
TEST_USER_ID=0
TEST_SUBSCRIPTION_ID=sub_test_placeholder
TEST_CUSTOMER_ID=cus_test_placeholder
TEST_SESSION_ID=cs_test_placeholder
TEST_PRICE_ID=price_test_placeholder

# 其他压测脚本使用的 JWT Token
# export JWT_TOKEN=your_jwt_token_here
